# ===== 复制本文件为 .env 并填入真实值 =====
# .env 已被 .gitignore 忽略, 不会进 git

# 服务端口
PORT=8080

# 与发版/表单平台约定的 inbound token (本服务自己生成, 告诉对方)
AUTH_TOKEN=请生成一个高熵字符串
# 运维管理接口 token (本服务自己生成)
ADMIN_TOKEN=请生成一个高熵字符串

# MySQL 连接 (公司库)
# 注意: 密码含 @ : / ? # % 等保留字符时需 URL encode
DB_URL=mysql+pymysql://domain_switch_rw:你的新密码@172.25.10.90:32518/domain_switch?charset=utf8mb4

# Redis (分布式锁)
REDIS_URL=redis://localhost:6379/0

# 阿里云 OOS
ALIYUN_AK=
ALIYUN_SK=
ALIYUN_REGION=cn-beijing

# 飞书表单平台
FORM_PLATFORM_URL=
FORM_PLATFORM_TOKEN=
FORM_PLATFORM_ROLLBACK_PATH=/api/openapi/node/rollback

# 钉钉通知 (可选, 不填则走 dry-run 打日志)
DINGTALK_WEBHOOK=
